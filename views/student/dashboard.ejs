<%- include('../layouts/header') %>

    <style>
        /* Consistent Dark Theme Palette - BRIGHTENED FOR VISIBILITY */
        :root {
            --shadow-accent: #7c3aed;
            --shadow-accent-hover: #6d28d9;
            --shadow-bg: #0b0f19;
            --shadow-card: #111827;
            --shadow-text: #f8fafc;
            --shadow-muted: #cbd5e1;
            --shadow-border: rgba(255, 255, 255, 0.15);
        }

        body {
            background-color: var(--shadow-bg);
            color: var(--shadow-text) !important;
        }

        /* Dashboard Specific Styles */
        .dashboard-card {
            background-color: var(--shadow-card);
            border-radius: 1rem;
            border: 1px solid var(--shadow-border) !important;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            overflow: hidden;
        }

        .custom-header-bg {
            background: linear-gradient(135deg, #4c1d95, #7c3aed);
            color: white !important;
            border-bottom: none;
        }

        .secondary-header {
            background-color: rgba(255, 255, 255, 0.03);
            color: var(--shadow-text) !important;
            border-bottom: 1px solid var(--shadow-border);
        }

        /* Search Bar Styles */
        .search-container {
            background-color: rgba(0, 0, 0, 0.2);
            border-bottom: 1px solid var(--shadow-border);
        }

        .search-input-group .input-group-text {
            background-color: rgba(0, 0, 0, 0.4);
            border: 1px solid var(--shadow-border);
            border-right: none;
            color: var(--shadow-muted);
        }

        .search-input-group .form-control {
            background-color: rgba(0, 0, 0, 0.4);
            border: 1px solid var(--shadow-border);
            border-left: none;
            color: white;
        }

        .search-input-group .form-control:focus {
            box-shadow: none;
            border-color: var(--shadow-accent);
        }

        .search-input-group:focus-within .input-group-text,
        .search-input-group:focus-within .form-control {
            border-color: var(--shadow-accent);
            border-top-color: var(--shadow-accent) !important;
            border-bottom-color: var(--shadow-accent) !important;
        }

        /* FIXED TABLE STYLES FOR MOBILE RESPONSIVENESS */
        .table-custom {
            color: var(--shadow-text) !important;
            --bs-table-bg: transparent;
            --bs-table-hover-bg: rgba(124, 58, 237, 0.1);
            margin-bottom: 0;
            width: 100%;
            table-layout: fixed; /* THIS IS THE MAGIC FIX FOR MOBILE TABLES */
        }

        .table-custom thead th {
            background-color: rgba(0, 0, 0, 0.3);
            color: var(--shadow-muted) !important;
            border-bottom: 1px solid var(--shadow-border);
            font-weight: 600;
            letter-spacing: 0.5px;
            white-space: nowrap;
        }

        .table-custom td {
            vertical-align: middle;
            border-bottom: 1px solid var(--shadow-border);
            color: #ffffff !important;
            word-wrap: break-word; /* Ensures long text wraps inside the fixed cell */
            white-space: normal;
        }

        /* Quantity Input Styling */
        .qty-input {
            width: 100%;
            max-width: 80px;
            text-align: center;
            background-color: rgba(0, 0, 0, 0.4) !important;
            border: 1px solid rgba(255, 255, 255, 0.2) !important;
            color: #ffffff !important;
        }

        .qty-input:focus {
            background-color: rgba(0, 0, 0, 0.6) !important;
            box-shadow: 0 0 0 0.25rem rgba(124, 58, 237, 0.25);
            border-color: var(--shadow-accent) !important;
            color: #ffffff !important;
        }

        /* Order History Scrollbar */
        .order-history-list {
            max-height: 550px;
            overflow-y: auto;
            background-color: var(--shadow-card);
        }

        .order-history-list::-webkit-scrollbar { width: 6px; }
        .order-history-list::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.2); }
        .order-history-list::-webkit-scrollbar-thumb {
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }
        .order-history-list::-webkit-scrollbar-thumb:hover { background-color: rgba(124, 58, 237, 0.5); }

        /* List group updates */
        .list-group-item {
            background-color: transparent !important;
            color: var(--shadow-text) !important;
            border-bottom: 1px solid var(--shadow-border) !important;
        }

        /* Buttons */
        .btn-primary {
            background-color: var(--shadow-accent);
            border-color: var(--shadow-accent);
            color: white;
        }

        .btn-primary:hover,
        .btn-primary:focus {
            background-color: var(--shadow-accent-hover);
            border-color: var(--shadow-accent-hover);
            color: white;
        }

        .btn-danger-soft {
            background-color: rgba(239, 68, 68, 0.12);
            border: 1px solid rgba(239, 68, 68, 0.35);
            color: #fca5a5;
        }

        .btn-danger-soft:hover {
            background-color: rgba(239, 68, 68, 0.2);
            color: white;
        }

        /* Utilities */
        .badge-status {
            font-size: 0.85em;
            padding: 0.5em 0.8em;
            border-radius: 20px;
            letter-spacing: 0.5px;
        }

        .text-success { color: #34d399 !important; }
        .text-muted { color: var(--shadow-muted) !important; }
        .bg-light-dark {
            background-color: rgba(0, 0, 0, 0.4) !important;
            border: 1px solid var(--shadow-border) !important;
        }
        .history-item-text { color: #e2e8f0 !important; }

        .queue-banner,
        .qr-panel {
            background: linear-gradient(135deg, rgba(17, 24, 39, 0.95), rgba(30, 41, 59, 0.9));
            border: 1px solid var(--shadow-border);
            border-radius: 1rem;
            padding: 1rem 1.25rem;
            height: 100%;
        }

        .queue-count {
            font-size: clamp(1.8rem, 4vw, 2.6rem);
            font-weight: 800;
            color: #f8fafc;
            line-height: 1;
        }

        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1rem;
            padding: 1rem;
        }

        .menu-card {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.98), rgba(17, 24, 39, 0.95));
            border: 1px solid var(--shadow-border);
            border-radius: 1rem;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            min-height: 100%;
        }

        .menu-card-image {
            width: 100%;
            height: 150px;
            object-fit: cover;
            background: linear-gradient(135deg, rgba(124, 58, 237, 0.2), rgba(59, 130, 246, 0.15));
        }

        .menu-card-placeholder {
            width: 100%;
            height: 150px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, rgba(124, 58, 237, 0.2), rgba(15, 23, 42, 0.9));
            color: rgba(255, 255, 255, 0.8);
            font-size: 2.2rem;
        }

        .menu-card-body {
            padding: 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            flex: 1;
        }

        .menu-card-title {
            font-weight: 700;
            font-size: 1.05rem;
            margin: 0;
            color:white;
        }

        .menu-card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.75rem;
            margin-top: auto;
        }

        .qr-image {
            width: min(100%, 220px);
            border-radius: 1rem;
            border: 1px solid rgba(255, 255, 255, 0.14);
            background: white;
            padding: 0.5rem;
        }

        /* --- RESPONSIVE MEDIA QUERIES --- */
        @media (max-width: 768px) {
            .dashboard-card { border-radius: 0.75rem; }
            .qty-input { max-width: 60px; }
            
            /* Stack the total and button on mobile */
            .checkout-footer {
                flex-direction: column !important;
                align-items: stretch !important;
                gap: 1rem !important;
            }
            .checkout-total-wrapper {
                display: flex;
                justify-content: space-between;
                width: 100%;
            }
        }
    </style>

    <div class="container-fluid py-3 py-md-4 mb-5">

        <div class="d-flex align-items-center justify-content-center justify-content-md-start mb-4 pb-3 border-bottom"
            style="border-color: var(--shadow-border) !important;">
            <i class="fa-solid fa-house-user fa-2x me-3" style="color: var(--shadow-accent);"></i>
            <h2 class="mb-0 fw-bold text-white fs-3 fs-md-2">Student Dashboard</h2>
        </div>
        
        <div class="row g-3 g-md-4 mb-4">
            <div class="col-lg-5">
                <div class="queue-banner">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="text-uppercase small fw-bold text-muted mb-2">Live Queue</div>
                            <div class="queue-count"><span id="queue-count"><%= activeQueueCount %></span>/<%= queueLimit %></div>
                            <div id="queue-status-text" class="small mt-2 <%= queueAvailable ? 'text-success' : 'text-danger' %>">
                                <%= queueAvailable ? 'Orders are open right now.' : 'Queue is full. Please wait for a slot.' %>
                            </div>
                        </div>
                        <div class="badge <%= queueAvailable ? 'bg-success-subtle text-success border border-success' : 'bg-danger-subtle text-danger border border-danger' %> px-3 py-2">
                            <%= queueAvailable ? 'Open' : 'Full' %>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="qr-panel text-center text-md-start">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-4 text-center">
                            <% if (canteenQrUrl) { %>
                                
                                <img src="<%= canteenQrUrl %>" alt="Canteen QR Code" class="qr-image">
                            <% } else { %>
                                <div class="qr-image d-flex align-items-center justify-content-center text-dark fw-bold">QR</div>
                            <% } %>
                        </div>
                        <div class="col-md-8">
                            <div class="text-uppercase small fw-bold text-info mb-2">Scan To Pay</div>
                            <h5 class="fw-bold text-white mb-2">Canteen QR Payment</h5>
                            <p class="text-muted mb-0">Students can scan or take a screenshot of this QR and complete payment before showing the coupon at the counter.</p>
                            <% if (!canteenQrUrl) { %>
                                <div class="small text-warning mt-2">Set <code>CANTEEN_QR_URL</code> in the environment to show the real payment QR.</div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="live-coupon-container" class="mb-4"></div>
        
        <div class="row g-3 g-md-4">
            <div class="col-lg-8">
                <div class="card dashboard-card h-100">
                    <div class="card-header custom-header-bg d-flex align-items-center p-3 p-md-4">
                        <i class="fa-solid fa-utensils me-3 fs-5"></i>
                        <h5 class="mb-0 fw-bold text-white">Place New Order</h5>
                    </div>

                    <div class="card-body p-0 d-flex flex-column">

                        <div class="p-3 search-container">
                            <div class="input-group search-input-group">
                                <span class="input-group-text">
                                    <i class="fa-solid fa-search"></i>
                                </span>
                                <input type="text" id="menu-search" class="form-control"
                                    placeholder="Search for food items..." onkeyup="filterMenu()">
                            </div>
                        </div>

                        <div class="table-responsive flex-grow-1 d-none">
                            <table class="table table-hover table-custom">
                                <thead class="text-uppercase small">
                                    <tr>
                                        <th class="ps-3 ps-md-4 py-3" style="width: 50%;">Item</th>
                                        <th class="py-3 text-start" style="width: 25%;">Price</th>
                                        <th class="pe-3 pe-md-4 py-3 text-end" style="width: 25%;">Quantity</th>
                                    </tr>
                                </thead>
                                <tbody id="menu-items-legacy">
                                    <% products.sort((a, b)=>
                                        a.name.toLowerCase().localeCompare(b.name.toLowerCase())).forEach(p=> { %>
                                        <tr class="menu-row">
                                            <td class="item-name fw-bold ps-3 ps-md-4 fs-6 fs-sm-5">
                                                <%= p.name %>
                                            </td>
                                            <td class="text-success fw-bold text-start">₹<span class="item-price">
                                                    <%= p.price %>
                                                </span></td>
                                            <td class="pe-3 pe-md-4 d-flex justify-content-end align-items-center">
                                                <input type="number"
                                                    class="form-control form-control-sm qty-input rounded-3 shadow-sm item-qty"
                                                    value="0" min="0" onchange="calcTotal()">
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>

                        <div id="menu-items" class="menu-grid">
                            <% products.sort((a, b)=>
                                a.name.toLowerCase().localeCompare(b.name.toLowerCase())).forEach(p=> { %>
                                <div class="menu-row menu-card">
                                    <% if (p.imageUrl) { %>
                                        <img src="<%= p.imageUrl %>" alt="<%= p.name %>" class="menu-card-image">
                                    <% } else { %>
                                        <div class="menu-card-placeholder">
                                            <i class="fa-solid fa-bowl-food"></i>
                                        </div>
                                    <% } %>
                                    <div class="menu-card-body">
                                        <p class="menu-card-title item-name"><%= p.name %></p>
                                        <div class="text-success fw-bold fs-5">Rs.<span class="item-price"><%= p.price %></span></div>
                                        <div class="menu-card-footer">
                                            <span class="small text-muted">Quantity</span>
                                            <input type="number"
                                                class="form-control form-control-sm qty-input rounded-3 shadow-sm item-qty"
                                                value="0" min="0" onchange="calcTotal()">
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                        </div>

                        <div class="p-3 p-md-4 d-flex justify-content-between align-items-center checkout-footer"
                            style="background-color: rgba(0,0,0,0.3); border-top: 1px solid var(--shadow-border);">
                            <div class="checkout-total-wrapper align-items-center">
                                <h5 class="m-0 text-muted me-2 text-uppercase fw-bold fs-6 fs-sm-5">Total:</h5>
                                <h3 class="m-0 fw-bold fs-4 fs-sm-3" style="color: var(--shadow-accent);">₹<span
                                        id="grandTotal">0</span></h3>
                            </div>
                            <button id="confirm-order-btn"
                                class="btn btn-primary btn-lg rounded-3 px-4 fw-bold shadow-lg d-flex justify-content-center align-items-center gap-2 w-100 w-md-auto"
                                onclick="submitOrder()" <%= queueAvailable ? '' : 'disabled' %>>
                                <i class="fa-solid fa-cart-arrow-down"></i>
                                <span>CONFIRM ORDER</span>
                            </button>
                        </div>

                        <div id="order-msg" class="px-4 pb-2"></div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card dashboard-card h-100 mt-3 mt-lg-0">
                    <div class="card-header secondary-header d-flex align-items-center p-3 p-md-4">
                        <i class="fa-solid fa-clock-rotate-left me-2 text-muted fs-5"></i>
                        <h5 class="mb-0 fw-bold text-white">My Orders</h5>
                    </div>

                    <div class="card-body p-0 order-history-list">
                        <ul class="list-group list-group-flush rounded-0" id="student-orders-list">
                            <% orders.forEach(o=> { %>
                                <li class="list-group-item p-3 p-md-4">

                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <span
                                            class="badge badge-status <%= o.status==='Fulfilled' ? 'bg-success text-white' : o.status==='Rejected' ? 'bg-danger text-white' : o.status==='Cancelled' ? 'bg-secondary text-white' : 'bg-warning text-dark' %> shadow-sm">
                                            <%= o.status %>
                                        </span>
                                        <strong class="fs-5" style="color: var(--shadow-accent);">₹<%= o.totalAmount %>
                                        </strong>
                                    </div>

                                    <small class="text-muted d-block mb-3 fw-medium">
                                        <i class="fa-regular fa-calendar-days me-1"></i>
                                        <%= o.orderTime.toLocaleString() %>
                                    </small>

                                    <div class="bg-light-dark rounded-3 p-2 p-md-3 border">
                                        <ul class="mb-0 ps-3 small text-light">
                                            <% o.items.forEach(i=> { %>
                                                <li class="mb-1">
                                                    <span class="fw-bold" style="color: var(--shadow-accent);">
                                                        <%= i.quantity %>x
                                                    </span>
                                                    <span class="ms-1 history-item-text">
                                                        <%= i.itemName %>
                                                    </span>
                                                </li>
                                                <% }) %>
                                        </ul>
                                    </div>

                                    <% if (o.status === 'Pending' && (Date.now() - new Date(o.orderTime).getTime()) <= 5 * 60 * 1000) { %>
                                        <div class="mt-3 text-end">
                                            <button class="btn btn-sm btn-danger-soft fw-bold" onclick="cancelOrder('<%= o._id %>')">
                                                <i class="fa-solid fa-xmark me-1"></i> Cancel Order
                                            </button>
                                        </div>
                                    <% } %>

                                </li>
                                <% }) %>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <audio id="notificationSound" src="https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3"
        preload="auto"></audio>

    <script>
        let audioUnlocked = false;

        function playNotificationSound() {
            const audio = document.getElementById('notificationSound');
            if (!audio) return;

            audio.pause();
            audio.currentTime = 0;
            audio.play().catch(() => {
                if (!audioUnlocked && window.AudioContext) {
                    const context = new AudioContext();
                    const oscillator = context.createOscillator();
                    const gain = context.createGain();
                    oscillator.type = 'sine';
                    oscillator.frequency.setValueAtTime(880, context.currentTime);
                    gain.gain.setValueAtTime(0.001, context.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.15, context.currentTime + 0.02);
                    gain.gain.exponentialRampToValueAtTime(0.001, context.currentTime + 0.4);
                    oscillator.connect(gain);
                    gain.connect(context.destination);
                    oscillator.start();
                    oscillator.stop(context.currentTime + 0.4);
                }
            });
        }

        // 1. Unlock Audio on first interaction to bypass browser Autoplay policies
        document.body.addEventListener('click', function unlockAudio() {
            const audio = document.getElementById('notificationSound');
            audio.play().then(() => {
                audio.pause();
                audio.currentTime = 0;
                audioUnlocked = true;
                document.body.removeEventListener('click', unlockAudio);
                console.log("Audio Unlocked successfully!");
            }).catch(e => {
                // Ignore errors
            });
        }, { once: true });

        // 2. Menu Search Function
        function filterMenu() {
            const input = document.getElementById("menu-search").value.toLowerCase();
            const rows = document.querySelectorAll(".menu-row");

            rows.forEach(row => {
                const itemName = row.querySelector(".item-name").textContent.toLowerCase();
                if (itemName.includes(input)) {
                    row.style.display = ""; // Show row
                } else {
                    row.style.display = "none"; // Hide row
                }
            });
        }

        // 3. Variables for Orders
        let knownStatuses = {};
        let isFirstLoad = true;

        // Ask the server for order updates every 3 seconds
        setInterval(fetchStudentOrders, 3000);

        async function fetchStudentOrders() {
            try {
                const response = await fetch('/student/api/orders');
                const orders = await response.json();

                const ul = document.getElementById('student-orders-list');
                if (!ul) return;

                let html = '';
                let statusChanged = false;

                orders.forEach(o => {
                    // --- SOUND LOGIC ---
                    if (!isFirstLoad && knownStatuses[o._id] === 'Pending' && (o.status === 'Fulfilled' || o.status === 'Rejected')) {
                        statusChanged = true;
                    }
                    knownStatuses[o._id] = o.status; 

                    const badgeClass = getOrderBadgeClass(o.status);
                    const orderDate = new Date(o.orderTime).toLocaleString();
                    const itemsListHtml = o.items.map(i => `
                            <li class="mb-1">
                                <span class="fw-bold" style="color: var(--shadow-accent);">${i.quantity}x</span>
                                <span class="ms-1 history-item-text">${i.itemName}</span>
                            </li>`).join('');
                    const cancelButtonHtml = canCancelOrder(o)
                        ? `
                            <div class="mt-3 text-end">
                                <button class="btn btn-sm btn-danger-soft fw-bold" onclick="cancelOrder('${o._id}')">
                                    <i class="fa-solid fa-xmark me-1"></i> Cancel Order
                                </button>
                            </div>
                        `
                        : '';

                    html += `
                    <li class="list-group-item p-3 p-md-4">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge badge-status ${badgeClass} shadow-sm">${o.status}</span>
                            <strong class="fs-5" style="color: var(--shadow-accent);">₹${o.totalAmount}</strong>
                        </div>
                        <small class="text-muted d-block mb-3 fw-medium">
                            <i class="fa-regular fa-calendar-days me-1"></i> ${orderDate}
                        </small>
                        <div class="bg-light-dark rounded-3 p-2 p-md-3 border">
                            <ul class="mb-0 ps-3 small text-light">
                                ${itemsListHtml}
                            </ul>
                        </div>
                        ${cancelButtonHtml}
                    </li>`;
                });

                ul.innerHTML = html;
                isFirstLoad = false;

                // Play sound if a status turned to Fulfilled or Rejected
                if (statusChanged) {
                    playNotificationSound();
                }

            } catch (error) {
                console.error("Error fetching student orders:", error);
            }
        }

        function canCancelOrder(order) {
            return order.status === 'Pending' && (Date.now() - new Date(order.orderTime).getTime()) <= 5 * 60 * 1000;
        }

        function getOrderBadgeClass(status) {
            if (status === 'Fulfilled') return 'bg-success text-white';
            if (status === 'Rejected') return 'bg-danger text-white';
            if (status === 'Cancelled') return 'bg-secondary text-white';
            return 'bg-warning text-dark';
        }

        async function refreshQueueStatus() {
            try {
                const response = await fetch('/student/api/queue-status');
                const data = await response.json();
                document.getElementById('queue-count').innerText = data.activeQueueCount;

                const statusText = document.getElementById('queue-status-text');
                const button = document.getElementById('confirm-order-btn');

                statusText.innerText = data.queueAvailable
                    ? 'Orders are open right now.'
                    : `Queue is full. Please wait until it drops below ${data.queueLimit}.`;
                statusText.className = `small mt-2 ${data.queueAvailable ? 'text-success' : 'text-danger'}`;

                if (button) {
                    button.disabled = !data.queueAvailable;
                }
            } catch (error) {
                console.error('Failed to refresh queue status:', error);
            }
        }

        async function cancelOrder(orderId) {
            const msgDiv = document.getElementById('order-msg');

            try {
                const response = await fetch(`/student/order/cancel/${orderId}`, {
                    method: 'POST'
                });
                const data = await response.json();

                if (data.success) {
                    msgDiv.innerHTML = `<div class="alert alert-success rounded-0 border-dark">${data.message}</div>`;
                    await fetchStudentOrders();
                    fetchActiveCoupons();
                    refreshQueueStatus();
                } else {
                    msgDiv.innerHTML = `<div class="alert alert-danger rounded-0 border-dark">${data.message}</div>`;
                }
            } catch (error) {
                msgDiv.innerHTML = '<div class="alert alert-danger rounded-0 border-dark">Failed to cancel order.</div>';
            }
        }

        // 4. Variables for Coupons
        let knownCoupons = [];
        let isFirstCouponLoad = true;

        // Poll for active coupons every 3 seconds
        setInterval(fetchActiveCoupons, 3000);
        setInterval(refreshQueueStatus, 3000);
        fetchActiveCoupons(); // Run immediately on load
        refreshQueueStatus();

        async function fetchActiveCoupons() {
            try {
                const response = await fetch('/student/api/coupons');
                const coupons = await response.json();
                const container = document.getElementById('live-coupon-container');

                // If there are no coupons, clear the UI and reset trackers
                if (coupons.length === 0) {
                    container.innerHTML = '';
                    knownCoupons = [];
                    isFirstCouponLoad = false;
                    return;
                }

                let html = '';
                let newCouponAdded = false;
                let currentCoupons = [];

                coupons.forEach(coupon => {
                    currentCoupons.push(coupon.couponCode);

                    // If it's NOT the first load, and this specific coupon code is new, flag it!
                    if (!isFirstCouponLoad && !knownCoupons.includes(coupon.couponCode)) {
                        newCouponAdded = true;
                    }

                    // Responsive flex classes for the coupon card
                    html += `
                    <div class="card bg-dark border-info shadow-lg mb-3" style="border-width: 2px; border-style: dashed;">
                        <div class="card-body d-flex flex-column flex-sm-row justify-content-between align-items-center p-3 p-md-4 gap-3 text-center text-sm-start">
                            <div>
                                <h6 class="text-uppercase text-info fw-bold mb-1">
                                    <i class="fa-solid fa-check-circle me-1"></i> Payment Verified
                                </h6>
                                <h2 class="text-white fw-bold mb-0 tracking-wider">
                                    ${coupon.couponCode}
                                </h2>
                                <small class="text-muted">Show this code at the counter to collect your food.</small>
                            </div>
                            <div class="text-end d-none d-sm-block">
                                <i class="fa-solid fa-qrcode fa-3x text-info opacity-50"></i>
                            </div>
                        </div>
                    </div>`;
                });

                container.innerHTML = html;

                // Play the sound if a new coupon was added
                if (newCouponAdded) {
                    playNotificationSound();
                }

                // Update tracker variables for the next cycle
                knownCoupons = currentCoupons;
                isFirstCouponLoad = false;

            } catch (error) {
                console.error("Error fetching coupons:", error);
            }
        }

        window.fetchStudentOrders = fetchStudentOrders;
        window.fetchActiveCoupons = fetchActiveCoupons;
        window.refreshQueueStatus = refreshQueueStatus;
    </script>
    <%- include('../layouts/footer') %>
